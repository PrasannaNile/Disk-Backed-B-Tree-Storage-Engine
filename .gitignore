# ==========================================
# Database Engine Artifacts (Exclude Data)
# ==========================================
# Ignore the actual binary database files generated by the engine
data/*.db
data/*.bin
*.db
*.bin

# ==========================================
# Build System & Output Binaries
# ==========================================
# Ignore CMake build artifacts and temporary compilation outputs
build/
build_*/
out/
bin/
lib/

# Object files and compiled libraries
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe

# ==========================================
# IDE & Code Editor Configurations
# ==========================================
# VS Code files
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Visual Studio files
.vs/
*.user
*.suo
*.sln

# JetBrains / CLion files
.idea/
cmake-build-*/

# ==========================================
# Operating System Garbage
# ==========================================
Thumbs.db
.DS_Store

# ========================================
# Others
# ========================================
*.pdf
